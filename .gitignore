## Ignore Visual Studio temporary files, build results, and
## files generated by popular IDEs.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/

# SQLite transient databases / lock files
*.db-shm
*.db-wal

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
